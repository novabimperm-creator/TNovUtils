<Window x:Class="TNovUtils.TypeFilterWPF"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:local="clr-namespace:TNovUtils"
        xmlns:sys="clr-namespace:System;assembly=mscorlib"
        KeyDown="VisibilityFilterWPF_KeyDown" Height="510" Width="420" MinHeight="400" MinWidth="400"
        
        
    WindowStartupLocation="CenterScreen" 
            Background="White" BorderBrush="#FF008E43" BorderThickness="1"
            ResizeMode="NoResize" WindowStyle="None">
    <Window.Resources>
        <!-- Стиль с полным шаблоном -->
        <Style x:Key="CustomButtonStyle" TargetType="Button">
            <Setter Property="Background" Value="#F0F0F0"/>
            <Setter Property="Foreground" Value="Black"/>
            <Setter Property="BorderBrush" Value="#CCCCCC"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <!-- Убираем SystemColors -->
                        <ControlTemplate.Resources>
                            <SolidColorBrush x:Key="{x:Static SystemColors.ControlBrushKey}" 
                                         Color="Transparent"/>
                            <SolidColorBrush x:Key="{x:Static SystemColors.HighlightBrushKey}" 
                                         Color="Transparent"/>
                        </ControlTemplate.Resources>

                        <Border x:Name="border"
                            Background="{TemplateBinding Background}"
                            BorderBrush="{TemplateBinding BorderBrush}"
                            BorderThickness="{TemplateBinding BorderThickness}"
                            CornerRadius="2">
                            <ContentPresenter HorizontalAlignment="Center"
                                          VerticalAlignment="Center"
                                          Margin="{TemplateBinding Padding}"/>
                        </Border>

                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <!-- Прямое указание цвета -->
                                <Setter TargetName="border" 
                                    Property="Background" 
                                    Value="#FF008E43"/>
                                <!-- Цвет заголовка -->
                                <Setter Property="Foreground" Value="White"/>
                            </Trigger>

                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="border" 
                                    Property="Background" 
                                    Value="#FF008E43"/>
                                <!-- Темнее -->
                            </Trigger>

                            <Trigger Property="IsEnabled" Value="False">
                                <Setter TargetName="border" 
                                    Property="Opacity" 
                                    Value="0.5"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>
    <WindowChrome.WindowChrome>
        <WindowChrome CaptionHeight="30"
              ResizeBorderThickness="5"
              GlassFrameThickness="0"
              CornerRadius="0"/>
    </WindowChrome.WindowChrome>
    

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="30"/>
            <RowDefinition Height="40"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="50"/>
            <RowDefinition Height="50"/>
            <RowDefinition Height="50"/>
        </Grid.RowDefinitions>
        
        <StackPanel VerticalAlignment="Center"   Grid.Row="0"  >
            <Border Height="30" 
                Background="#FF008E43" 
                VerticalAlignment="Top"
                MouseDown="Border_MouseDown">
                <TextBlock Text="TNov - Типофильтр" 
                       Foreground="White"
                       VerticalAlignment="Center"
                       Margin="10,0"/>
            </Border>
        </StackPanel>
        
        <DockPanel Grid.Row="1" Margin="10,8,10,4">
            <Grid>
                <TextBox BorderBrush="#CCCCCC" TextChanged="tbSearch_TextChanged" x:Name="tbSearch" VerticalAlignment="Center" Height="24"
                 Padding="6,0" VerticalContentAlignment="Center" ToolTip="Поиск по имени типа"/>
                <TextBlock Margin="8,0,0,0" VerticalAlignment="Center" IsHitTestVisible="false"
                   FontSize="{Binding FontSize, ElementName=tbSearch}">
          <FrameworkElement.Style>
            <Style TargetType="{x:Type TextBlock}">
              <Setter Property="TextBlock.Text" Value="Поиск типов..."/>
              <Setter Property="UIElement.Visibility" Value="Collapsed"/>
              <Style.Triggers>
                <MultiDataTrigger>
                  <MultiDataTrigger.Conditions>
                    <Condition Binding="{Binding Text, ElementName=tbSearch}" Value=""/>
                    <Condition Binding="{Binding IsFocused, ElementName=tbSearch}" Value="False"/>
                  </MultiDataTrigger.Conditions>
                  <Setter Property="UIElement.Visibility" Value="Visible"/>
                </MultiDataTrigger>
              </Style.Triggers>
            </Style>
          </FrameworkElement.Style>
                </TextBlock>
            </Grid>
        </DockPanel>
        <TreeView x:Name="categoryTreeView" Grid.Row="2" Margin="10" Padding="1,5" BorderBrush="#CCCCCC"
              VirtualizingPanel.IsVirtualizing="true" VirtualizingPanel.VirtualizationMode="Recycling">
            <FrameworkElement.Resources>
                <Style TargetType="{x:Type ContentPresenter}">
                    <Setter Property="ContentPresenter.RecognizesAccessKey" Value="false"/>
                </Style>
                <DataTemplate DataType="{x:Type local:TypeFilterElementTypeViewModel}">
                    <CheckBox IsChecked="{Binding IsSelected, Mode=TwoWay}">
                        <TextBlock Text="{Binding Name}"/>
                    </CheckBox>
                </DataTemplate>
                <HierarchicalDataTemplate x:Key="{DataTemplateKey {x:Type local:TypeFilterCategoryViewModel}}"
                  DataType="{x:Type local:TypeFilterCategoryViewModel}" ItemsSource="{Binding ElementTypesView}">
                    <CheckBox IsChecked="{Binding IsSelected, Mode=TwoWay}">
                        <TextBlock Text="{Binding Name}"/>
                    </CheckBox>
                </HierarchicalDataTemplate>
            </FrameworkElement.Resources>
        </TreeView>
        <Grid Row="3" Margin="0,0,0,0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>
            <Button Click="btn_Hide_Click" x:Name="btn_Hide" Content="Скрыть" Margin="10,0" VerticalAlignment="Center"
              Height="25" Width="100" HorizontalAlignment="Left" Style="{StaticResource CustomButtonStyle}" />
            <Button Click="btn_Isolate_Click" x:Name="btn_Isolate" Content="Изолировать" Margin="10,0"
              VerticalAlignment="Center" Height="25" Width="100" Grid.Column="1" Style="{StaticResource CustomButtonStyle}" />
            <Button Click="btn_Select_Click" x:Name="btn_Select" Content="Выбрать" Margin="10,0"
              VerticalAlignment="Center" Height="25" Width="100" Grid.Column="2" HorizontalAlignment="Right" Style="{StaticResource CustomButtonStyle}" />
        </Grid>
        <Grid Row="4">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="160"/>
            </Grid.ColumnDefinitions>
            <TextBox x:Name="textBox_FilterName" Height="26" Margin="10,0" VerticalAlignment="Center"
               VerticalContentAlignment="Center" HorizontalContentAlignment="Center" BorderBrush="#CCCCCC"/>
            <Button Click="btn_CreateFilter_Click" x:Name="btn_CreateFilter" Content="Скрыть фильтром" Margin="0"
              VerticalAlignment="Center" Width="140" Height="25" Grid.Column="1" Style="{StaticResource CustomButtonStyle}" />
        </Grid>
        <Button Click="btn_Ok_Click" x:Name="btn_Ok" Content="Уйти" Grid.Row="5" HorizontalAlignment="Right"
            Margin="0,0,10,10" VerticalAlignment="Bottom" Width="100" Height="25" Style="{StaticResource CustomButtonStyle}" />
    </Grid>
</Window>