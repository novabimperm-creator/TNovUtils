<Window x:Class="TNovUtils.RevitServer"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:TNovUtils" 
        mc:Ignorable="d" Width="400"
        d:DataContext="{d:DesignInstance local:RevitServerViewModel}"
            WindowStartupLocation="CenterScreen" 
                                       AllowsTransparency="True"
Background="Transparent" 
            ResizeMode="NoResize" WindowStyle="None">
    <Window.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="/TNovCommon;component/ButtonStyles.xaml"/>

            </ResourceDictionary.MergedDictionaries>

            <local:InverseConverter x:Key="InverseConverter"/>
        </ResourceDictionary>
    </Window.Resources>
    <WindowChrome.WindowChrome>
        <WindowChrome CaptionHeight="30"
              ResizeBorderThickness="5"
              GlassFrameThickness="0"
              CornerRadius="12"/>
    </WindowChrome.WindowChrome>
    <Border CornerRadius="12"
    Background="White"
    BorderBrush="#FF008E43"
    BorderThickness="1">
        <Grid>
            <!-- Верхняя панель (кастомный заголовок) -->
            <Border Height="30" CornerRadius="12 12 0 0"
    Background="#FF008E43" 
    VerticalAlignment="Top"
    MouseDown="Border_MouseDown">
                <StackPanel Orientation="Horizontal">
                    <Button Style="{StaticResource RoundButtonStyle}" 
Click="escButton_Click" Content="✕"
HorizontalAlignment="Center" VerticalAlignment="Center"
Width="20" Height="20" Margin="5,0"
WindowChrome.IsHitTestVisibleInChrome="True"/>
                    <Button Style="{StaticResource RoundButtonStyle3}" 
Content=""
HorizontalAlignment="Center" VerticalAlignment="Center"
Width="20" Height="20" Margin="0"
WindowChrome.IsHitTestVisibleInChrome="True"/>
                    <TextBlock Text="Revit Server" 
Foreground="White"
VerticalAlignment="Center"
Margin="10,0"/>
                </StackPanel>

            </Border>

            <!-- Основное содержимое -->
            <Border Margin="0,30,0,0">

                <StackPanel VerticalAlignment="Center" Margin="5">


                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" >

                        <TreeView MinHeight="100" MaxHeight="400" Width="370" x:Name="treeView"
    BorderBrush="{x:Null}"
    BorderThickness="0"
    ItemsSource="{Binding Path=Nodes, Mode=TwoWay}"
    Margin="5">
                            <TreeView.ItemTemplate>
                                <HierarchicalDataTemplate ItemsSource="{Binding Path=Children, Mode=TwoWay}">
                                    <StackPanel Orientation="Horizontal">
                                        <CheckBox
                IsChecked="{Binding  IsChecked, Mode=TwoWay}"
                            IsEnabled="{Binding IsLocked, Converter={StaticResource InverseConverter}}"
                Uid="{Binding Id}" />
                                        <TextBlock Text="{Binding Text}" />
                                    </StackPanel>
                                </HierarchicalDataTemplate>
                            </TreeView.ItemTemplate>
                        </TreeView>

                    </StackPanel>



                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">

                        <Button Style="{StaticResource CustomButtonStyle}" Content="Отмена" x:Name="escButton" IsCancel="True" Click="escButton_Click" MinWidth="60" MinHeight="25" Margin="20 5 5 5" />
                        <Button Style="{StaticResource CustomButtonStyle}" Content="Выбрать" x:Name="acceptButton" IsDefault="True" Click="acceptButton_Click" MinWidth="110" Margin="5"/>
                    </StackPanel>

                </StackPanel>

            </Border>
        </Grid>

    </Border>

</Window>
