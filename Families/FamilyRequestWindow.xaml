<Window x:Class="TNovUtils.FamilyRequestWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Заявка на семейство" Height="540" Width="600"
        WindowStyle="None" AllowsTransparency="True" Background="Transparent"
        WindowStartupLocation="CenterOwner">
    <Window.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="/TNovCommon;component/ButtonStyles.xaml"/>
            </ResourceDictionary.MergedDictionaries>
        </ResourceDictionary>
    </Window.Resources>
    <WindowChrome.WindowChrome>
        <WindowChrome CaptionHeight="30" ResizeBorderThickness="5"
                      GlassFrameThickness="0" CornerRadius="12"/>
    </WindowChrome.WindowChrome>
    <Border CornerRadius="12" Background="White" BorderBrush="#FF008E43"
            BorderThickness="1">
        <Grid>
            <Border Height="30" CornerRadius="12 12 0 0" Background="#FF008E43"
                    VerticalAlignment="Top" MouseDown="TitleBar_MouseDown">
                <StackPanel Orientation="Horizontal">
                    <Button Style="{StaticResource RoundButtonStyle}" Content="✕"
                            Click="btnCancel_Click"
                            Width="20" Height="20" Margin="5,0"
                            WindowChrome.IsHitTestVisibleInChrome="True"/>
                    <Button Style="{StaticResource RoundButtonStyle2}" 
Click="HelpButton_Click" Content="?"
HorizontalAlignment="Center" VerticalAlignment="Center"
Width="20" Height="20" Margin="0"
WindowChrome.IsHitTestVisibleInChrome="True"/>
                    <TextBlock Text="Заявка на семейство" Foreground="White"
                               VerticalAlignment="Center" Margin="10,0"/>
                </StackPanel>
            </Border>

            <Border Margin="0,30,0,0">
                <Grid Margin="10">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <!-- Заявитель: имя и роль -->
                    <StackPanel Grid.Row="0" Margin="0,5">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock x:Name="tbNamePrefix" FontSize="14" FontWeight="SemiBold"
                                       Foreground="Gray" VerticalAlignment="Center"/>
                            <TextBlock x:Name="tbUserName" Margin="5,0,0,0" FontSize="14" FontWeight="Bold"
                                       Foreground="Black" VerticalAlignment="Center"/>
                        </StackPanel>
                        <StackPanel Orientation="Horizontal" Margin="0,5,0,0">
                            <TextBlock x:Name="tbRolePrefix" FontSize="14" FontWeight="SemiBold"
                                       Foreground="Gray" VerticalAlignment="Center"/>
                            <TextBlock x:Name="tbUserRole" Margin="5,0,0,0" FontSize="14" FontWeight="Bold"
                                       Foreground="Black" VerticalAlignment="Center"/>
                        </StackPanel>
                    </StackPanel>

                    <!-- Ответственный -->
                    <StackPanel Grid.Row="1" Orientation="Horizontal" Margin="0,5">
                        <Label Width="120" Content="Ответственный:" VerticalAlignment="Center"/>
                        <ComboBox Name="cmbResponsible" Width="300" IsEditable="False"
                                  SelectedIndex="0" ToolTip="Выберите ответственного"/>
                    </StackPanel>

                    <!-- Объект -->
                    <StackPanel Grid.Row="2" Orientation="Horizontal" Margin="0,5">
                        <Label Width="120" Content="Объект:" VerticalAlignment="Center"/>
                        <ComboBox Name="cmbProject" Width="300" IsEditable="True"
                                  ToolTip="Выберите проект из списка или введите вручную"/>
                    </StackPanel>

                    <!-- Описание -->
                    <StackPanel Grid.Row="3" Margin="0,5">
                        <Label Content="Описание *" Margin="0,0,0,3"/>
                        <TextBox Name="txtDescription" Height="60" TextWrapping="Wrap" AcceptsReturn="True"/>
                    </StackPanel>

                    <!-- Желаемые сроки -->
                    <StackPanel Grid.Row="4" Orientation="Horizontal" Margin="0,5">
                        <Label Width="120" Content="Желаемые сроки:" VerticalAlignment="Center"/>
                        <DatePicker Name="dpDeadline" Width="120" Margin="0,0,10,0"/>
                        <TextBox Name="txtTime" Text="15:30" Width="60" ToolTip="Формат ЧЧ:ММ"/>
                    </StackPanel>

                    <!-- Фото / образец -->
                    <StackPanel Grid.Row="5" Margin="0,10,0,5">
                        <Label Content="Фото / образец:"/>
                        <Border BorderBrush="Gray" BorderThickness="1" Background="#F0F0F0" Height="100" Margin="0,5">
                            <Grid>
                                <Image Name="imgPreview" Stretch="Uniform" Visibility="Collapsed"/>
                                <TextBlock Name="tbPhotoHint" Text="Нажмите Ctrl+V для вставки изображения"
                                           VerticalAlignment="Center" HorizontalAlignment="Center"
                                           Foreground="Gray" TextAlignment="Center"/>
                            </Grid>
                        </Border>
                        <Button Style="{StaticResource CustomButtonStyle}" Name="btnClearPhoto" Content="Очистить" Width="80" Height="25" HorizontalAlignment="Left"
                                Margin="0,5,0,0" Click="btnClearPhoto_Click"/>
                    </StackPanel>

                    <!-- Кнопки действий -->
                    <StackPanel Grid.Row="6" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,15,0,0">
                        
                        <Button Style="{StaticResource CustomButtonStyle}" Name="btnCancel" Content="Отмена" Width="80" Height="25" Click="btnCancel_Click"/>

                        <Button Style="{StaticResource CustomButtonStyle}" Name="btnOk" Content="Отправить заявку" Width="120" Height="25"
        Margin="10,0,0,0" Click="btnOk_Click"/>
                    </StackPanel>
                </Grid>
            </Border>
        </Grid>
    </Border>
</Window>